{
  "version": 2,
  "name": "eos-agent",
  "builds": [
    {
      "src": "eos-agent.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/eos-agent.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}